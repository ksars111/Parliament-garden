# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_MAPS_API_KEY: Required for Google Maps.
# Get one at https://console.cloud.google.com/google/maps-apis/credentials
VITE_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# CESIUM_ION_ACCESS_TOKEN: Required for CesiumJS.
# Get one at https://ion.cesium.com/
VITE_CESIUM_ION_ACCESS_TOKEN="YOUR_CESIUM_ION_ACCESS_TOKEN"

# Cloudinary Configuration: Required for image uploads.
# Get your Cloud Name and create an Unsigned Upload Preset in your Cloudinary Dashboard.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
