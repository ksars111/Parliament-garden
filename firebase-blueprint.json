{
  "entities": {
    "PlantMarker": {
      "title": "Plant Marker",
      "description": "A marker for a plant in the garden.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the marker." },
        "uid": { "type": "string", "description": "The UID of the user who created the marker." },
        "latitude": { "type": "number", "description": "The latitude of the plant." },
        "longitude": { "type": "number", "description": "The longitude of the plant." },
        "name": { "type": "string", "description": "The name of the plant." },
        "botanicalName": { "type": "string", "description": "The latin botanical name of the plant." },
        "description": { "type": "string", "description": "The description of the plant." },
        "imageUrl": { "type": "string", "description": "The URL or base64 data of the plant's image." },
        "createdAt": { "type": "number", "description": "The timestamp when the marker was created." },
        "type": { "type": "string", "enum": ["tree", "plant"], "description": "The type of the marker." }
      },
      "required": ["id", "uid", "latitude", "longitude", "name", "createdAt", "type"]
    }
  },
  "firestore": {
    "/garden/data": {
      "schema": {
        "type": "object",
        "properties": {
          "markers": {
            "type": "array",
            "items": { "$ref": "#/entities/PlantMarker" }
          }
        }
      },
      "description": "Single document containing all garden markers for read optimization."
    },
    "/snapshots/{snapshotId}": {
      "schema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "uid": { "type": "string" },
          "name": { "type": "string" },
          "createdAt": { "type": "number" },
          "markers": {
            "type": "array",
            "items": { "$ref": "#/entities/PlantMarker" }
          }
        },
        "required": ["id", "uid", "name", "createdAt", "markers"]
      },
      "description": "Historical snapshots of the garden for restoration purposes."
    },
    "/test/connection": {
      "schema": "object",
      "description": "Connection test document."
    }
  }
}
