rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: markers
    // Document ID: markerId
    // Fields:
    //   - id: string (required)
    //   - uid: string (required)
    //   - latitude: number (required)
    //   - longitude: number (required)
    //   - name: string (required)
    //   - description: string (optional)
    //   - imageUrl: string (optional)
    //   - createdAt: number (required)
    //   - type: string (required, enum: ['tree', 'plant'])
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidMarker(data) {
      return data.keys().hasAll(['id', 'uid', 'latitude', 'longitude', 'name', 'createdAt', 'type']) &&
             data.id is string && data.id.size() < 100 &&
             data.uid is string && data.uid.size() < 100 &&
             data.latitude is number &&
             data.longitude is number &&
             data.name is string && data.name.size() < 500 &&
             (!('description' in data) || (data.description is string && data.description.size() < 10000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 1048576)) &&
             data.createdAt is number &&
             data.type in ['tree', 'plant'];
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "karlsarsfield@gmail.com" && request.auth.token.email_verified == true));
    }

    match /test/connection {
      allow read: if true;
    }

    match /markers/{markerId} {
      allow read: if true;
      
      // Allow create if authenticated and UID matches
      allow create: if isAuthenticated() && 
                      isValidMarker(request.resource.data) && 
                      request.resource.data.id == markerId &&
                      request.resource.data.uid == request.auth.uid;
      
      // Allow update if authenticated. 
      // We ensure the internal ID matches the document ID and doesn't change.
      // We also ensure the original author UID and createdAt timestamp are preserved.
      allow update: if isAuthenticated() && 
                      isValidMarker(request.resource.data) &&
                      request.resource.data.id == markerId &&
                      request.resource.data.id == resource.data.id &&
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.createdAt == resource.data.createdAt;
      
      allow delete: if isAuthenticated() && 
                      (request.auth.uid == resource.data.uid || isAdmin());
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
