rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: markers
    // Document ID: markerId
    // Fields:
    //   - id: string (required)
    //   - uid: string (required)
    //   - latitude: number (required)
    //   - longitude: number (required)
    //   - name: string (required)
    //   - description: string (optional)
    //   - imageUrl: string (optional)
    //   - createdAt: number (required)
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidMarker(data) {
      return data.keys().hasAll(['id', 'uid', 'latitude', 'longitude', 'name', 'createdAt']) &&
             data.id is string && data.id.size() < 100 &&
             data.uid is string && data.uid.size() < 100 &&
             data.latitude is number &&
             data.longitude is number &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             (!('description' in data) || (data.description is string && data.description.size() < 2000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 2000)) &&
             data.createdAt is number;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "karlsarsfield@gmail.com" && request.auth.token.email_verified == true));
    }

    match /test/connection {
      allow read: if true;
    }

    match /markers/{markerId} {
      allow read: if true;
      
      // Allow create/update/delete if authenticated (including anonymous)
      allow create: if isAuthenticated() && isValidMarker(request.resource.data);
      allow update: if isAuthenticated() && isValidMarker(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
