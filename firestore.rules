// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: markers
// Document ID: {markerId}
// Fields:
//   - id: string (required) - Unique ID
//   - uid: string (required) - User ID of creator
//   - latitude: number (required) - Latitude
//   - longitude: number (required) - Longitude
//   - name: string (required, max 100 chars) - Plant name
//   - description: string (optional, max 2000 chars) - Description
//   - imageUrl: string (optional, max 5MB if base64, or URL) - Image
//   - createdAt: number (required) - Creation timestamp
//   - type: string (required, enum: ['tree', 'plant']) - Marker type
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function isValidMarker(data) {
      return data.keys().hasAll(['id', 'uid', 'latitude', 'longitude', 'name', 'createdAt', 'type']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 50 &&
             data.uid is string && data.uid.size() > 0 &&
             data.latitude is number &&
             data.longitude is number &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 5000000)) &&
             data.createdAt is number &&
             data.type in ['tree', 'plant'];
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "karlsarsfield@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /markers/{markerId} {
      // Allow anyone to read markers (public view)
      allow read: if true;
      
      // Allow authenticated users to create markers
      allow create: if isAuthenticated() && 
                    isValidMarker(request.resource.data) && 
                    request.resource.data.uid == request.auth.uid;
      
      // Allow owners or admins to update/delete
      allow update: if (isDocOwner() || isAdmin()) && 
                    isValidMarker(request.resource.data) &&
                    request.resource.data.uid == resource.data.uid && // UID immutable
                    request.resource.data.id == resource.data.id;     // ID immutable
                    
      allow delete: if isDocOwner() || isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
