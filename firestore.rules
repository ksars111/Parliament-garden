// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: markers
// Document ID: {markerId}
// Fields:
//   - id: string (required) - Unique ID
//   - uid: string (required) - User ID of creator
//   - latitude: number (required) - Latitude
//   - longitude: number (required) - Longitude
//   - name: string (required) - Plant name
//   - description: string (optional) - Description
//   - imageUrl: string (optional) - Image URL
//   - createdAt: number (required) - Creation timestamp
//   - type: string (required, enum: ['tree', 'plant']) - Marker type
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidMarker(data) {
      return data.keys().hasAll(['id', 'latitude', 'longitude', 'name', 'createdAt', 'type']) &&
             data.id is string && data.id.size() > 0 &&
             data.latitude is number &&
             data.longitude is number &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 500 &&
             data.get('description', '') is string && data.get('description', '').size() <= 10000 &&
             data.get('imageUrl', '') is string && data.get('imageUrl', '').size() <= 1000000 &&
             data.createdAt is number &&
             data.type in ['tree', 'plant'];
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email == "karlsarsfield@gmail.com" && request.auth.token.email_verified == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /markers/{markerId} {
      allow read: if true;
      
      // Allow public creation of markers
      allow create: if isValidMarker(request.resource.data) && 
                    request.resource.data.id == markerId;
      
      // Allow public updates for this collaborative demo
      allow update: if isValidMarker(request.resource.data) &&
                    request.resource.data.id == markerId;
                    
      // Allow public deletion for this collaborative demo
      allow delete: if true;
    }

    match /test/connection {
      allow read: if true;
    }
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
